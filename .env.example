# Telegram credentials. Keep real values only in the untracked .env file.
BOT_TOKEN=
ADMIN_IDS=

# Public Telegram Mini App URL. WEBAPP_URL is a backwards-compatible fallback.
MINIAPP_URL=
# WEBAPP_URL=

# Embedded HTTP server.
MINIAPP_HOST=0.0.0.0
MINIAPP_PORT=3000
# PORT=3000
MINIAPP_ENABLED=1

# Never enable debug authentication in a public or production environment.
MINIAPP_DEBUG=0

# Standalone web sessions. Production mode requires an HTTPS public origin,
# Secure cookies, and disabled debug authentication.
WEBAPP_ENV=production
WEBAPP_PUBLIC_ORIGIN=https://app.example.ru
WEBAPP_SESSION_TTL_SECONDS=43200
WEBAPP_SESSION_IDLE_SECONDS=7200
WEBAPP_COOKIE_SECURE=1

# Enable only behind a controlled proxy that sanitizes X-Forwarded-* headers.
TRUST_PROXY_HEADERS=0

# Required for deployment: replace with a private, persistent absolute path.
DB_DIR=/absolute/path/to/private/sewing-web-data
# SHARED_DIR=/absolute/path/to/legacy-shared-data
